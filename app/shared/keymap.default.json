{
  "version": 1,
  "bindings": [
    { "action": "action.tab.new", "key": "Ctrl+T", "when": "global" },
    { "action": "action.tab.close", "key": "Ctrl+W", "when": "global" },
    { "action": "action.tab.restore", "key": "Ctrl+Shift+T", "when": "global" },
    { "action": "action.tab.next", "key": "Ctrl+Tab", "when": "global" },
    { "action": "action.tab.prev", "key": "Ctrl+Shift+Tab", "when": "global" },
    { "action": "action.tab.reader", "key": "Ctrl+Alt+R", "when": "global" },
    { "action": "action.omnibox.focus", "key": "Ctrl+L", "when": "global" },
    { "action": "action.omnibox.focus", "key": "F6", "when": "global" },
    { "action": "action.page.reload", "key": "Ctrl+R", "when": "global" },
    { "action": "action.page.reload", "key": "F5", "when": "global" },
    { "action": "action.window.incognito", "key": "Ctrl+Shift+N", "when": "global" },
    { "action": "action.history.open", "key": "Ctrl+H", "when": "global" },
    { "action": "action.downloads.open", "key": "Ctrl+J", "when": "global" },
