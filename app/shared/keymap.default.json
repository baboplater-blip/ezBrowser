    { "action": "action.qrcode.show", "key": "Ctrl+Shift+Q", "when": "global" },
    { "action": "action.devtools.toggle", "key": "F12", "when": "global" },
    { "action": "action.devtools.toggle", "key": "Ctrl+Shift+I", "when": "global" },
    { "action": "action.nav.back", "key": "Alt+Left", "when": "global" },
