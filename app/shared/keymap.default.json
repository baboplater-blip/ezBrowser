    { "action": "action.workspace.switch.1", "key": "Ctrl+Alt+1", "when": "global" },
    { "action": "action.workspace.switch.2", "key": "Ctrl+Alt+2", "when": "global" },
    { "action": "action.workspace.switch.3", "key": "Ctrl+Alt+3", "when": "global" },
    { "action": "action.workspace.switch.4", "key": "Ctrl+Alt+4", "when": "global" },
    { "action": "action.workspace.switch.5", "key": "Ctrl+Alt+5", "when": "global" },
    { "action": "action.tab.move.next.workspace", "key": "Ctrl+Shift+PageDown", "when": "global" },
