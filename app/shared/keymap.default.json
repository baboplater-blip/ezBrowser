    { "action": "action.palette.open", "key": "Ctrl+Shift+P", "when": "global" },
    { "action": "action.tab.search", "key": "Ctrl+Shift+A", "when": "global" },
    { "action": "action.userchrome.reload", "key": "Ctrl+Alt+Shift+R", "when": "chrome" },
    { "action": "action.userscript.toggle", "key": "Ctrl+Shift+U", "when": "global" },
    { "action": "action.policy.open", "key": "Ctrl+Shift+Y", "when": "global" },
    { "action": "action.settings.open", "key": "Ctrl+,", "when": "global" },
    { "action": "action.password.open", "key": "Ctrl+Shift+;", "when": "global" },
    { "action": "action.ai.open", "key": "Ctrl+Shift+Space", "when": "global" },

    { "action": "action.sidepanel.left.toggle", "key": "Ctrl+B", "when": "global" },
    { "action": "action.sidepanel.right.toggle", "key": "Ctrl+Alt+B", "when": "global" },
    { "action": "action.bookmark.bar.toggle", "key": "Ctrl+Shift+B", "when": "global" },

    { "action": "action.screenshot.area", "key": "Ctrl+Shift+S", "when": "global" },
