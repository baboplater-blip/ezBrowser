    { "action": "action.translate.page", "key": "Ctrl+Shift+L", "when": "global" },

    { "action": "action.workspace.next", "key": "Ctrl+Alt+Right", "when": "global" },
    { "action": "action.workspace.prev", "key": "Ctrl+Alt+Left", "when": "global" },
